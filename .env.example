# Copy this file to `.env` and fill in your key:
#     cp .env.example .env
#
# ClearFrame's pipeline (run.py) calls the OpenAI API, so this key is required.
# Get one at https://platform.openai.com/api-keys
#
# `.env` is gitignored — your real key never gets committed.

OPENAI_API_KEY=sk-your-key-here

# ── Hosting only (leave unset for local use) ─────────────────────────────
# If set, the site prompts for a shared password before anyone can run the
# pipeline — keeps a public URL from spending your OpenAI credit. Any username
# works; only the password is checked.
CLEARFRAME_PASSWORD=

# Set HOST=0.0.0.0 when running inside a container/host so it accepts outside
# traffic. Locally, leave it unset (defaults to 127.0.0.1). PORT is usually
# injected by the host; locally it defaults to 8000.
HOST=

