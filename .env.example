# Copy this file to `.env` and fill in your key:
#     cp .env.example .env
#
# ClearFrame's pipeline (run.py) calls the OpenAI API, so this key is required.
# Get one at https://platform.openai.com/api-keys
#
# `.env` is gitignored — your real key never gets committed.

OPENAI_API_KEY=sk-your-key-here
